# Noir / bb build artifacts
circuits/**/target/
*.gz
*.witness

# proof + vk outputs
artifacts/
# stray root-level VK dump (canonical copies live in backend/vks/); anchored so backend/vks stays tracked
/vks/

# vendored verifier repos (cloned separately, pinned to specific commits)
vendor/

# Foundry (EVM bridge): vendored deps + build output (deps pinned, fetch via evm/README.md)
evm/lib/
evm/out/
evm/cache/
evm/broadcast/

# Rust
target/

# bridge-prover proof artifacts (seal.hex / journal.hex emitted by `host --prove`)
bridge-prover/out/

# soroban test snapshots (generated by `cargo test`)
**/test_snapshots/

# e2e driver state (scripts/e2e.sh persists deployed contracts/addresses here)
.e2e/

# misc
.DS_Store
.gstack/
.skills/

# bulky one-off worst-case testnet fixtures (regenerable via scripts/gen_worstcase_fixtures.sh)
contracts/settlement/tests/fixtures/book_worst/
